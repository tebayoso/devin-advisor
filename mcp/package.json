{
  "name": "devin-scope-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Remote MCP server (Cloudflare Workers + D1) for devin-scope: task decomposition, adversarial review, and cross-session memory.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test test/*.test.ts test/*.test.mjs",
    "test:integration": "vitest run",
    "test:integration:watch": "vitest",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute devin_scope --file=./schema.sql",
    "db:migrate": "wrangler d1 execute devin_scope --file=./migrations/0001_workspace_isolation.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.4.31",
    "@cloudflare/workers-types": "4.20240725.0",
    "tsx": "4.19.2",
    "typescript": "5.5.4",
    "vitest": "1.5.3",
    "wrangler": "3.65.1"
  }
}
